{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": ".",
  "installCommand": "npm install --omit=dev --ignore-scripts --no-audit --no-fund",
  "buildCommand": "echo \"api-only deploy: skip frontend build (tsc/vite are devDeps, not installed)\"",
  "rewrites": [
    { "source": "/", "destination": "/landing/index.html" },
    { "source": "/share/:path*", "destination": "/api/share/:path*" },
    { "source": "/sweep", "destination": "/api/sweep" }
  ],
  "crons": [{ "path": "/sweep", "schedule": "17 3 * * *" }]
}
